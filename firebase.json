{
  "hosting": {
    "target": "vaudtaxai",
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "run": {
          "serviceId": "vaudtaxai-web",
          "region": "europe-west6"
        }
      },
      {
        "source": "**",
        "run": {
          "serviceId": "vaudtaxai-ui",
          "region": "europe-west6"
        }
      }
    ]
  }
}
