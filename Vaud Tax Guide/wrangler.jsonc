{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "vaudtaxai-ui",
  "compatibility_date": "2025-09-24",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/server.ts",
  // Custom domains are attached via the Cloudflare dashboard after the
  // tax-gpt.online zone is Active on Cloudflare (nameservers swapped at
  // Namecheap). Adding `routes` here while the zone is still
  // "Pending Nameserver Update" makes `wrangler deploy` fail with
  // "Could not find zone". See infra/cloudflare/README.md.
  "observability": {
    "enabled": true
  }
}
