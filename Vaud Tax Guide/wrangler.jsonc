{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "vaudtaxai-ui",
  "compatibility_date": "2025-09-24",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/server.ts",
  // Publish to <name>.<account>.workers.dev. Required once because
  // tax-gpt.online Custom Domains are attached via the dashboard after
  // the zone goes Active (avoids "Could not find zone" deploy failures).
  // workers.dev URL stays live as a backup even after Custom Domains
  // are attached.
  "workers_dev": true,
  "observability": {
    "enabled": true
  }
}
