# VaudTaxAI environment template.
# Copy to .env (gitignored) and fill values. Never commit .env. Never echo secrets.

# ---------- Active provider ----------
# `azure` (recommended) routes RAG, extraction, and embeddings to Azure AI Foundry.
# `groq` is the demo fallback only.
MODEL_PROVIDER=azure

# ---------- Active corpus / scope ----------
ACTIVE_TAX_YEAR=2025
ACTIVE_CANTON=VD
ACTIVE_RAG_CORPUS=vd_2025
# Optional: explicit path to the corpus PDF. Default resolution looks for
# ./vd_2025.pdf, then data/official/vd_2025.pdf, then TaxAI2025/vd_2025.pdf.
# ACTIVE_CORPUS_PATH=

# ---------- Azure OpenAI (AI Foundry) ----------
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-10-21

# Deployment names you created in Azure AI Foundry. Names are arbitrary; the
# router resolves them from these env vars.
AZURE_OPENAI_DEPLOYMENT_RAG=
AZURE_OPENAI_DEPLOYMENT_EXTRACTION=
AZURE_OPENAI_DEPLOYMENT_REASONING=

# Embeddings. text-embedding-3-large @ 3072 dims, cosine similarity.
# Do NOT switch to text-embedding-ada-002.
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072
VECTOR_SIMILARITY=cosine

# Optional: override the index dir. Default is keyed by corpus + embedding family
# (e.g. ./chroma_db_vd_2025_te3_large). A change to embedding model, dimensions,
# source hash, or tax year forces a rebuild.
# RAG_INDEX_DIR=

# ---------- Groq (demo fallback only) ----------
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ---------- Demo mode ----------
# Empty = live pipeline. `replay` = bypass live OCR/LLM and use fixtures.
DEMO_MODE=replay
DEMO_SCENARIO=expat_c_permit_basic

# ---------- Local persistence ----------
DB_PATH=taxpilot_user_data.db
